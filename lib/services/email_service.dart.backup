    required String location,
    required String lawyerName,
  }) async {
    try {
      final htmlContent =
          '''
        <div style="font-family: Arial, sans-serif; max-width: 600px; margin: auto; padding: 20px; border: 1px solid #eee; border-radius: 10px; background: white;">
          <div style="text-align: center; margin-bottom: 30px;">
            <h2 style="color: #FF6B00; margin: 0;">⚠️ Hearing Date Updated</h2>
            <p style="color: #E65100; margin: 10px 0 0 0;">Important Schedule Change</p>
          </div>
          
          <p style="font-size: 16px; color: #333;">Dear <strong>$recipientName</strong>,</p>
