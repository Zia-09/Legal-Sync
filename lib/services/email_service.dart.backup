              <li>Update your calendar immediately</li>
              <li>Confirm availability with your lawyer: <strong>$lawyerName</strong></li>
              <li>Make necessary travel arrangements</li>
              <li>Gather all required documents</li>
            </ul>
          </div>
          
          <p style="color: #666; font-size: 14px; margin-top: 20px;">If you have any concerns about this new date, please contact your lawyer right away.</p>
          
          <hr style="border: 0; border-top: 1px solid #eee; margin: 30px 0;" />
          <p style="text-align: center; font-size: 12px; color: #aaa;">&copy; 2026 LegalSync Elite. Serving justice with excellence.</p>
        </div>
      ''';

      await sendProfessionalEmail(
        to: toEmail,
        subject: '⚠️ Hearing Date Updated - $caseTitle',
        htmlContent: htmlContent,
      );
      print('✅ Hearing reminder email sent to $toEmail');
    } catch (e) {
      print('❌ Failed to send hearing reminder email: $e');
    }
  }

  /// 🔹 Send Login Notification Email
  Future<void> sendLoginNotificationEmail({
    required String toEmail,
    required String userName,
  }) async {
    try {
      final now = DateTime.now();
      final formattedDate =
          '${now.year}-${now.month.toString().padLeft(2, '0')}-${now.day.toString().padLeft(2, '0')}';
      final formattedTime =
          '${now.hour.toString().padLeft(2, '0')}:${now.minute.toString().padLeft(2, '0')}';

      final htmlContent =
          '''
        <div style="font-family: Arial, sans-serif; max-width: 600px; margin: auto; padding: 20px; border: 1px solid #eee; border-radius: 10px; background: white;">
          <div style="text-align: center; margin-bottom: 30px;">
            <h2 style="color: #FF6B00; margin: 0;">🔐 New Login Detected</h2>
            <p style="color: #666; margin: 10px 0 0 0;">Security Notification</p>
          </div>
          
          <p style="font-size: 16px; color: #333;">Dear <strong>$userName</strong>,</p>
          <p style="color: #666; line-height: 1.6;">We've detected a new login to your LegalSync account. Here are the details:</p>
          
          <div style="background: white; border: 2px solid #FF6B00; border-radius: 8px; padding: 20px; margin: 20px 0;">
            <h3 style="color: #FF6B00; margin: 0 0 15px 0; border-bottom: 2px solid #FF6B00; padding-bottom: 10px;">Login Information</h3>
            
            <table style="width: 100%; border-collapse: collapse;">
              <tr style="border-bottom: 1px solid #eee;">
                <td style="padding: 10px 0; color: #666; font-weight: bold;">📅 Date:</td>
                <td style="padding: 10px 0; color: #333; font-size: 16px;">$formattedDate</td>
              </tr>
              <tr style="border-bottom: 1px solid #eee;">
                <td style="padding: 10px 0; color: #666; font-weight: bold;">⏰ Time:</td>
                <td style="padding: 10px 0; color: #333; font-size: 16px;">$formattedTime</td>
              </tr>
              <tr style="border-bottom: 1px solid #eee;">
                <td style="padding: 10px 0; color: #666; font-weight: bold;">✅ Status:</td>
                <td style="padding: 10px 0; color: #2E7D32; font-weight: bold;">Verified</td>
              </tr>
            </table>
          </div>
          
          <div style="background-color: #fff3e0; padding: 15px; border-radius: 8px; margin: 20px 0; border-left: 4px solid #FF6B00;">
            <h4 style="color: #E65100; margin: 0 0 10px 0;">🔒 Security Reminder</h4>
            <ul style="margin: 0; padding-left: 20px; color: #333; font-size: 14px;">
              <li>If this wasn't you, secure your account immediately</li>
              <li>Change your password right away</li>
              <li>Review recent account activity</li>
              <li>Contact support if you notice anything suspicious</li>
            </ul>
          </div>
          
          <p style="color: #666; font-size: 14px; margin-top: 20px;">Your account security is our priority. If you have any concerns, please contact our support team.</p>
          
          <hr style="border: 0; border-top: 1px solid #eee; margin: 30px 0;" />
          <p style="text-align: center; font-size: 12px; color: #aaa;">&copy; 2026 LegalSync Elite. Protecting your legal interests.</p>
        </div>
      ''';

      await sendProfessionalEmail(
        to: toEmail,
        subject: '🔐 New Login to LegalSync',
        htmlContent: htmlContent,
      );
      print('✅ Login notification email sent to $toEmail');
    } catch (e) {
      print('❌ Failed to send login notification email: $e');
    }
  }

  /// 🔹 Send Hearing Scheduled Email
  Future<void> sendBillingNotificationEmail({
    required String toEmail,
    required String clientName,
    required String
    notificationType, // 'payment_received', 'billing_ready', 'subscription_update', etc.
    required Map<String, dynamic> billingDetails,
  }) async {
    try {
      String subject = 'Billing Notification - LegalSync';
      String titleText = 'Billing Update';
      String messageText = 'Your billing information has been updated.';
      String icon = '📧';

      switch (notificationType.toLowerCase()) {
        case 'payment_received':
          subject = '✅ Payment Received - Invoice Confirmed';
          titleText = 'Payment Confirmed';
          messageText =
              'Thank you! We have received your payment of \$${billingDetails['amount'] ?? 'N/A'}.';
          icon = '✅';
          break;
        case 'billing_ready':
          subject = '📋 New Invoice Ready';
          titleText = 'Invoice Available';
          messageText =
              'A new invoice for \$${billingDetails['amount'] ?? 'N/A'} is now available.';
          icon = '📋';
          break;
        case 'subscription_update':
          subject = '🔄 Subscription Updated';
          titleText = 'Subscription Change';
          messageText =
              'Your subscription has been ${billingDetails['action'] ?? 'updated'}.';
          icon = '🔄';
          break;
        case 'payment_failed':
          subject = '⚠️ Payment Failed - Action Required';
          titleText = 'Payment Issue';
          messageText =
              'Your recent payment attempt failed. Please update your payment method.';
          icon = '⚠️';
          break;
        case 'refund_issued':
          subject = '💰 Refund Processed';
          titleText = 'Refund Confirmation';
          messageText =
              'A refund of \$${billingDetails['amount'] ?? 'N/A'} has been processed.';
          icon = '💰';
          break;
      }

      final htmlContent =
          '''
        <div style="font-family: Arial, sans-serif; max-width: 600px; margin: auto; padding: 20px; border: 1px solid #eee; border-radius: 10px; background: white;">
          <div style="text-align: center; margin-bottom: 30px;">
            <h2 style="color: #FF6B00; margin: 0;">$icon $titleText</h2>
            <p style="color: #666; margin: 10px 0 0 0;">Billing Management</p>
          </div>
          
          <p style="font-size: 16px; color: #333;">Dear <strong>$clientName</strong>,</p>
          <p style="color: #666; line-height: 1.6;">$messageText</p>
          
          <div style="background-color: #f9f9f9; padding: 15px; border-radius: 8px; margin: 20px 0; border-left: 4px solid #FF6B00;">
            <h4 style="color: #FF6B00; margin: 0 0 10px 0;">📊 Billing Details</h4>
            <p style="margin: 0; color: #333;">
              ${billingDetails.entries.map((e) => '<strong>${e.key}:</strong> ${e.value}<br/>').join()}
            </p>
          </div>
          
          <p style="color: #666; font-size: 13px; margin-top: 20px;">For any questions regarding your billing, please contact our support team.</p>
          
          <hr style="border: 0; border-top: 1px solid #eee; margin: 30px 0;" />
          <p style="text-align: center; font-size: 12px; color: #aaa;">&copy; 2026 LegalSync Elite. Professional Legal Services Management.</p>
        </div>
      ''';

      await sendProfessionalEmail(
        to: toEmail,
        subject: subject,
        htmlContent: htmlContent,
      );
      print('✅ Billing notification sent to $toEmail');
    } catch (e) {
      print('❌ Failed to send billing notification: $e');
    }
  }
}

final emailService = EmailService();
