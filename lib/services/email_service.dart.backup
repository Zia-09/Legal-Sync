          <div style="background: white; border: 2px solid #FF6B00; border-radius: 8px; padding: 20px; margin: 20px 0;">
            <h3 style="color: #FF6B00; margin: 0 0 15px 0; border-bottom: 2px solid #FF6B00; padding-bottom: 10px;">Hearing Schedule Update</h3>
            
            <table style="width: 100%; border-collapse: collapse;">
              <tr style="border-bottom: 1px solid #eee;">
                <td style="padding: 10px 0; color: #666; font-weight: bold;">Case:</td>
                <td style="padding: 10px 0; color: #333;">$caseTitle</td>
              </tr>
              <tr style="border-bottom: 1px solid #ddd; background-color: #fff3e0;">
                <td style="padding: 10px 0; color: #E65100; font-weight: bold;">❌ Previous Date:</td>
                <td style="padding: 10px 0; color: #E65100; text-decoration: line-through;">$oldHearingDate</td>
              </tr>
              <tr style="border-bottom: 1px solid #eee; background-color: #e8f5e9;">
                <td style="padding: 10px 0; color: #2E7D32; font-weight: bold;">✅ New Date:</td>
