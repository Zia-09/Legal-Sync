            </table>
          </div>
          
          <div style="background-color: #e3f2fd; padding: 15px; border-radius: 8px; margin: 20px 0; border-left: 4px solid #2196F3;">
            <h4 style="color: #1565C0; margin: 0 0 10px 0;">📋 Action Required</h4>
