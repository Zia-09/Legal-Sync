  /// 🔹 Send Case Update Email via Resend
  Future<void> sendCaseUpdateEmail({
    required String toEmail,
    required String recipientName,
    required String caseTitle,
    required String caseNumber,
    required String
    updateType, // 'status_updated', 'note_added', 'document_added'
    required String updateDescription,
    required String newStatus,
  }) async {
    try {
      String icon = '📋';
      String titleText = 'Case Updated';

      switch (updateType.toLowerCase()) {
        case 'status_updated':
          icon = '✅';
          titleText = 'Case Status Changed';
          break;
        case 'note_added':
          icon = '📝';
          titleText = 'New Case Note';
          break;
        case 'document_added':
          icon = '📎';
          titleText = 'Document Uploaded';
          break;
      }

      final htmlContent =
          '''
        <div style="font-family: Arial, sans-serif; max-width: 600px; margin: auto; padding: 20px; border: 1px solid #eee; border-radius: 10px; background: white;">
          <div style="text-align: center; margin-bottom: 30px;">
            <h2 style="color: #FF6B00; margin: 0;">$icon $titleText</h2>
            <p style="color: #666; margin: 10px 0 0 0;">Your Case Has Been Updated</p>
          </div>
          
          <p style="font-size: 16px; color: #333;">Dear <strong>$recipientName</strong>,</p>
          <p style="color: #666; line-height: 1.6;">There's an important update on your case. Please review the details below:</p>
          
          <div style="background: white; border: 2px solid #FF6B00; border-radius: 8px; padding: 20px; margin: 20px 0;">
            <h3 style="color: #FF6B00; margin: 0 0 15px 0; border-bottom: 2px solid #FF6B00; padding-bottom: 10px;">Case Details</h3>
            
            <table style="width: 100%; border-collapse: collapse;">
              <tr style="border-bottom: 1px solid #eee;">
                <td style="padding: 10px 0; color: #666; font-weight: bold;">Case:</td>
                <td style="padding: 10px 0; color: #333;">$caseTitle</td>
              </tr>
              <tr style="border-bottom: 1px solid #eee;">
                <td style="padding: 10px 0; color: #666; font-weight: bold;">Case Number:</td>
                <td style="padding: 10px 0; color: #333;">$caseNumber</td>
              </tr>
              <tr style="border-bottom: 1px solid #eee;">
                <td style="padding: 10px 0; color: #666; font-weight: bold;">Update Type:</td>
                <td style="padding: 10px 0; color: #333;">$updateType</td>
              </tr>
              <tr style="border-bottom: 1px solid #eee;">
                <td style="padding: 10px 0; color: #666; font-weight: bold;">New Status:</td>
                <td style="padding: 10px 0; color: #FF6B00; font-weight: bold; font-size: 16px;">$newStatus</td>
              </tr>
            </table>
          </div>
          
          <div style="background-color: #f0f9ff; padding: 15px; border-radius: 8px; margin: 20px 0; border-left: 4px solid #FF6B00;">
            <h4 style="color: #FF6B00; margin: 0 0 10px 0;">📌 What Changed</h4>
            <p style="margin: 0; color: #333; line-height: 1.6;">$updateDescription</p>
          </div>
          
          <p style="color: #666; font-size: 14px; margin-top: 20px;">Log in to LegalSync to view full details and respond to your lawyer.</p>
          
          <hr style="border: 0; border-top: 1px solid #eee; margin: 30px 0;" />
          <p style="text-align: center; font-size: 12px; color: #aaa;">&copy; 2026 LegalSync Elite. Serving justice with excellence.</p>
        </div>
      ''';

      await sendProfessionalEmail(
        to: toEmail,
        subject: '$icon Case Update: $caseTitle',
        htmlContent: htmlContent,
      );
      print('✅ Case update email sent to $toEmail');
    } catch (e) {
      print('❌ Failed to send case update email: $e');
    }
  }

  /// 🔹 Send Hearing Reminder/Update Email via Resend
  Future<void> sendHearingReminderEmail({
    required String toEmail,
